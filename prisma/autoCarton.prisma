model autoCartonFaults {
  ID          Int                   @id @default(autoincrement())
  timestamp   DateTime
  line        Int
  machineType autoCartonMachineType
  faultCode   Int

  @@index([line, machineType])
}

model autoCartonFaultCodeLookup {
  ID           Int    @id @default(autoincrement())
  faultMessage String
}

enum autoCartonMachineType {
  Lidder
  iPack
  labeler
  erector
  barcoder
  addressLabler
  test
}
